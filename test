pipeline {
    agent {
        label 'AutoInferno-Production'
    }
    stages {
        stage('Run compare_lic') {
            steps {
                script {
                    currentBuild.displayName = env.BUILD_NUMBER
                    sh '''
                        su -s /bin/bash flames -c 'cd /opt/autoInferno/license_files && /home/flames/bin/compare_lic file1 file2'
                    '''
                }
            }
        }
    }
}
