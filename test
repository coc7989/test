import React from 'react';

function ApplyColors({ result }) {
    if (result.length !== 2) {
        return null; // Expected array length is 2
    }

    return (
        <div>
            <p>
                <span style={{ color: result[0] > result[1] ? 'red' : result[0] < result[1] ? 'blue' : 'black' }}>
                    {result[0]}
                </span>
                Feature(s) not in /opt/license_files/file1 :
            </p>
            <p>
                <span style={{ color: result[1] > result[0] ? 'red' : result[1] < result[0] ? 'blue' : 'black' }}>
                    {result[1]}
                </span>
                Feature(s) not in /opt/license_files/file2 :
            </p>
        </div>
    );
}

export default ApplyColors;
