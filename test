# Function to get user role from the database
def get_user_role(user_id):
    connection = cx_Oracle.connect(db_user, db_password, db_host + ':' + db_port + '/' + db_service)
    cursor = connection.cursor()
    cursor.execute("SELECT role FROM user_roles WHERE id = :user_id", {'user_id': user_id})
    role = cursor.fetchone()
    cursor.close()
    connection.close()
    return role[0] if role else None

