from flask import Flask, jsonify
import os

app = Flask(__name__)

@app.route('/read_files')
def read_files():
    folder_path = '/path/to/your/folder'  # Update this with the actual path to your folder
    modified_files_content = []

    for filename in os.listdir(folder_path):
        if filename.startswith("Modified_"):
            file_path = os.path.join(folder_path, filename)
            with open(file_path, 'r') as file:
                content = file.read()
                modified_files_content.append({filename: content})

    return jsonify(modified_files_content)

if __name__ == '__main__':
    app.run(debug=True)
