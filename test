// Find the index of the line containing "FEATURE NAME"
def featureIndex = -1
for (int i = 0; i < lines.size(); i++) {
    if (lines[i].contains("FEATURE NAME")) {
        featureIndex = i
        break
    }
}

// Check if "FEATURE NAME" was found and handle accordingly
if (featureIndex != -1) {
    // Initialize an empty list to store the filtered data lines
    def dataLines = []

    // Loop through lines starting from featureIndex + 1 and filter data lines
    for (int i = featureIndex + 1; i < lines.size(); i++) {
        def line = lines[i]
        // Check if the line contains "OMMITTED/ADDED"
        if (line.contains("OMMITTED/ADDED")) {
            // If it does, break out of the loop
            break
        }
        // Add the line to the dataLines list
        dataLines.add(line)
    }

    // Continue with your remaining code...
} else {
    // Handle case when "FEATURE NAME" is not found
    println "Error: 'FEATURE NAME' not found in the output."
}
