pipeline {
    agent {
        label 'AutoInferno-Production'
    }
    stages {
        stage('Compare License File') {
            steps {
                script {
                    currentBuild.displayName = env.BUILD_NUMBER
                    def output = sh(script: '''
                        su -s /bin/bash flames <<EOF
                        whoami
                        ls /opt/autoInferno/license_files
                        cd /opt/autoInferno/license_files
                        pwd
                        /home/flames/bin/compare_lic file1 file2
                        EOF
                    ''', returnStdout: true).trim()

                    def outputs = output.split('\n')
                    def diff = outputs[5]
                    echo "Difference: ${diff}"

                    def result = "{\"Difference\":\"${diff}\"}"
                    echo "Result: ${result}"

                    echo "Pipeline completed hurray"
                }
            }
        }
    }
}
