import React, { useState, useEffect } from "react"
import ReactDiffViewer from "react-diff-viewer-continued"

import axios from "axios"

const MyDiffViewer = () => {
  const [modifiedChunks, setModifiedChunks] = useState([])
  const [originalChunks, setOriginalChunks] = useState([])
  const [currentPage, setCurrentPage] = useState(0)
  const [totalChunks, setTotalChunks] = useState(0)

  useEffect(() => {
    loadChunks()
  }, [currentPage]) // Reload chunks whenever currentPage changes

  const loadChunks = async () => {
    try {
      const response = await axios.get(
        `http://localhost:5000/chunks?index=${currentPage}`
      )
      setModifiedChunks([response.data.modified_chunk])
      setOriginalChunks([response.data.original_chunk])
      setTotalChunks(response.data.total_chunks) // Set totalChunks received from backend
    } catch (error) {
      console.error("Error fetching chunks:", error)
    }
  }

  const loadNextPage = () => {
    setCurrentPage(currentPage + 1)
  }

  const loadPreviousPage = () => {
    setCurrentPage(currentPage - 1)
  }

  return (
    <div>
      {modifiedChunks.map((modifiedChunk, index) => (
        <ReactDiffViewer
          key={index}
          oldValue={originalChunks[index]}
          newValue={modifiedChunk}
          splitView={true}
        />
      ))}
      <div>
        <button onClick={loadPreviousPage} disabled={currentPage === 0}>
          Previous
        </button>
        <button
          onClick={loadNextPage}
          disabled={currentPage === totalChunks - 1}
        >
          Next
        </button>
      </div>
    </div>
  )
}

export default MyDiffViewer
