pipeline {
    agent any
    environment {
        ENV_FILE = credentials('your-credentials-id')
    }
    stages {
        stage('Build') {
            steps {
                // Copy the .env file to the workspace
                withCredentials([file(credentialsId: 'your-credentials-id', variable: 'ENV_FILE')]) {
                    sh 'cp $ENV_FILE .env'
                }
                // Run any necessary build steps for your Flask application
                sh 'pip install -r requirements.txt'
                // etc.
            }
        }
        stage('Deploy') {
            steps {
                // Deploy your Flask application
                // This might involve Docker build and push steps, or deploying to a server
                // Adjust according to your deployment strategy
            }
        }
    }
}
