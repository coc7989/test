pipeline {
    agent any

    stages {
        stage('Compare License File') {
            steps {
                script {
                    // Run the command and capture the output
                    def output = sh(script: '''
                        /home/flames/bin/compare_lic file1 file2
                    ''', returnStdout: true).trim()

                    // Split the output by newline and remove empty lines
                    def lines = output.split('\n').findAll { !it.trim().isEmpty() }

                    // Initialize featureIndex variable
                    def featureIndex = lines.indexOf { it.contains("FEATURE NAME") }

                    // Check if "FEATURE NAME" was found and handle accordingly
                    if (featureIndex != -1) {
                        // Initialize an empty array to store parsed data
                        def dataArray = []

                        // Loop through data lines and parse each line
                        for (int i = featureIndex + 1; i < lines.size(); i++) {
                            def line = lines[i]
                            // Check if the line contains "OMMITTED/ADDED"
                            if (line.contains("OMMITTED/ADDED")) {
                                // If it does, break out of the loop
                                break
                            }
                            // Split the line by whitespace to separate columns
                            def columns = line.split()
                            // Extract feature name, file1 value, and file2 value
                            def featureName = columns[0]
                            def file1Value = columns[1]
                            def file2Value = columns[2]
                            // Create a map with extracted data
                            def dataObject = [
                                feature_name: featureName,
                                file1: file1Value,
                                file2: file2Value
                            ]
                            // Add the dataObject to the dataArray
                            dataArray.add(dataObject)
                        }

                        // Convert the dataArray to JSON
                        def jsonData = groovy.json.JsonOutput.toJson(dataArray)

                        // Send HTTP request to Flask backend
                        httpRequest(
                            contentType: 'APPLICATION_JSON',
                            httpMode: 'POST',
                            requestBody: jsonData,
                            url: 'http://your-flask-backend-url'
                        )

                    } else {
                        // Handle case when "FEATURE NAME" is not found
                        println "Error: 'FEATURE NAME' not found in the output."
                    }
                }
            }
        }
    }
}
