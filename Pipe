pipeline {
    agent any
    stages {
        stage('Example') {
            steps {
                script {
                    // Run shell command to get the build log with max lines
                    def buildLog = sh(script: "echo '\${BUILD_LOG}' | tail -n 30", returnStdout: true).trim()

                    // Sending email notification with build log
                    mail to: 'recipient@example.com',
                         subject: 'Build Notification',
                         body: "Build Log:\n${buildLog}"
                }
            }
        }
    }
}
