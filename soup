important_heading = soup.find('h2', text=lambda text: text and 'Yellow - Important' in text)

# Navigate to the <div> tag containing the table
div_containing_table = important_heading.find_next('p').find_next('div')

# Find the table within the <div>
table = div_containing_table.find('table')

# Extract table headers
headers = [header.text.strip() for header in table.find_all('th')]

# Extract table rows
rows = []
for row in table.find_all('tr'):
    row_data = [cell.text.strip() for cell in row.find_all('td')]
    if row_data:  # Ignore empty rows
        rows.append(row_data)

# Print table headers and data
print("Headers:", headers)
for row in rows:
    print("Row:", row)
