important_section = soup.find(text="Yellow - Important").find_parent("h2")

# Find the table after the "Yellow - Important" section
table = important_section.find_next_sibling("table")

# Extract table headers
headers = [header.text.strip() for header in table.find_all('th')]

# Extract table rows
rows = []
for row in table.find_all('tr'):
    row_data = [cell.text.strip() for cell in row.find_all('td')]
    if row_data:  # Ignore empty rows
        rows.append(row_data)

# Print table headers and data
print("Headers:", headers)
for row in rows:
    print("Row:", row)
