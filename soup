# Find all table elements
tables = soup.find_all('table')

for table in tables:
    # Initialize variables to keep track of rowspan
    rowspan_map = {}

    # Extract table headers
    headers = [header.text.strip() for header in table.find_all('th')]

    # Extract table rows
    rows = []
    for row_idx, row in enumerate(table.find_all('tr')):
        row_data = []
        col_idx = 0
        for cell_idx, cell in enumerate(row.find_all(['td', 'th'])):
            # Check rowspan
            while (row_idx, col_idx) in rowspan_map:
                rowspan_map.pop((row_idx, col_idx))
                col_idx += 1

            rowspan = int(cell.get('rowspan', 1))
            colspan = int(cell.get('colspan', 1))
            cell_text = cell.text.strip()

            # Update rowspan map
            for i in range(rowspan):
                for j in range(colspan):
                    if (row_idx + i, col_idx + j) != (row_idx, col_idx):
                        rowspan_map[(row_idx + i, col_idx + j)] = True

            # Append cell value to row data
            row_data.append(cell_text)

            # Move to next column
            col_idx += 1

        # Append row data to rows
        rows.append(row_data)

    # Print table headers and data
    print("Headers:", headers)
    for row in rows:
        print("Row:", row)
    print()  # Print an empty line for readability
